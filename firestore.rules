rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/profiles/$(request.auth.uid))
        && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // profiles/{uid} — own/admin read; self-signup allowed for student-only;
    // user updates own non-role fields; admin can do anything.
    match /profiles/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if (isOwner(uid)
                        && request.resource.data.role == 'student'
                        && request.resource.data.email == request.auth.token.email)
                    || isAdmin();
      allow update: if (isOwner(uid)
                        && request.resource.data.role == resource.data.role
                        && request.resource.data.email == resource.data.email)
                    || isAdmin();
      allow delete: if isAdmin();
    }

    // support_requests — anyone can submit; owner reads own + can post a reply
    // when admin set status to waiting_for_response; admin has full control.
    match /support_requests/{id} {
      allow create: if true;
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.user_id == request.auth.uid);
      allow update: if isAdmin()
        || (isSignedIn()
            && resource.data.user_id == request.auth.uid
            && resource.data.status == 'waiting_for_response'
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['last_reply', 'last_reply_at', 'last_reply_by',
                           'status', 'updated_at'])
            && request.resource.data.status == 'pending'
            && request.resource.data.last_reply_by == request.auth.uid);
      allow delete: if isAdmin();
    }

    // devices — public read; admin write
    match /devices/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // problems — public read; admin write
    match /problems/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // troubleshooting_feedback — anyone insert; admin read/delete
    match /troubleshooting_feedback/{id} {
      allow create: if true;
      allow read, delete: if isAdmin();
      allow update: if false;
    }
  }
}
