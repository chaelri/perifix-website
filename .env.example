# Firebase — get these from
# https://console.firebase.google.com/project/<project-id>/settings/general/
# (Web app config — Project settings → General → Your apps → Web app)
# Copy this file to .env.local and fill in values for local dev.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Service account JSON for admin scripts (never bundled into the browser).
# Download from https://console.firebase.google.com/project/<project-id>/settings/serviceaccounts/adminsdk
# and save as ./firebase-service-account.json (gitignored).
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# Vercel serverless functions under api/admin/* read the service account as a
# single-line JSON string. Set this in Vercel Project Settings → Environment
# Variables. For local dev with `vercel dev`, paste the contents of your
# firebase-service-account.json file (single line, no surrounding quotes):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
