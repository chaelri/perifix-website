# Supabase — get these from
# https://supabase.com/dashboard/project/<project-ref>/settings/api
# Copy this file to .env.local and fill in values for local dev.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# New-format publishable key (sb_publishable_...). Safe to expose to the browser.
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Legacy anon JWT — only needed if any old code still imports it. Optional.
VITE_SUPABASE_ANON_KEY=

# Secret keys — NO VITE_ prefix so they're never bundled into the browser.
# Only used by Supabase CLI / Edge Functions / server-side scripts.
SUPABASE_SECRET_KEY=sb_secret_xxx
SUPABASE_SERVICE_ROLE_KEY=
