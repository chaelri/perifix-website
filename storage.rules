rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/profiles/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/profiles/$(request.auth.uid)).data.role == 'admin';
    }

    // step-images — public read, admin write, max 5MB, image types only
    match /step-images/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
